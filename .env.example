# Copy to `.env` (or export in your shell) to configure the client without
# writing anything to disk. Environment variables always win over the config file.

# The UCloud deployment to talk to.
UCLOUD_BASE_URL=https://cloud.sdu.dk

# The long-lived refresh token extracted once from a browser session.
# See the README ("Getting your refresh token") for how to obtain it.
UCLOUD_REFRESH_TOKEN=
